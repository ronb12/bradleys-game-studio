{
  "version": 2,
  "functions": {
    "api/generate.js": { "maxDuration": 120 }
  },
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/generate", "dest": "/api/generate.js" },
    { "src": "/api/publish",  "dest": "/api/publish.js"  },
    { "src": "/favicon.ico",  "dest": "/public/favicon.svg" },
    { "src": "/",             "dest": "/public/index.html" },
    { "src": "/(.*)",         "dest": "/public/$1"       }
  ]
}
