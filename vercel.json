{
  "version": 2,
  "builds": [
    { "src": "api/generate.js", "use": "@vercel/node", "config": { "maxDuration": 300, "memory": 1024 } },
    { "src": "api/billing.js", "use": "@vercel/node", "config": { "maxDuration": 60 } },
    { "src": "api/publish.js", "use": "@vercel/node", "config": { "maxDuration": 120 } },
    { "src": "api/studio.js", "use": "@vercel/node", "config": { "maxDuration": 300, "memory": 1024 } },
    { "src": "api/spatial.js", "use": "@vercel/node", "config": { "maxDuration": 300, "memory": 1024 } },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/generate", "dest": "/api/generate.js" },
    { "src": "/api/billing",  "dest": "/api/billing.js"  },
    { "src": "/api/publish",  "dest": "/api/publish.js"  },
    { "src": "/api/studio",   "dest": "/api/studio.js"   },
    { "src": "/api/spatial",  "dest": "/api/spatial.js"  },
    { "src": "/favicon.ico",  "dest": "/public/favicon.svg" },
    { "src": "/",             "dest": "/public/index.html" },
    { "src": "/(.*)",         "dest": "/public/$1"       }
  ]
}
