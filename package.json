{
  "name": "bradleys-game-studio",
  "version": "2.0.0",
  "description": "Bradley's Game Studio — BGS Engine with Spatial-01, Eva-01, 4D World Model, 5M+ AnimLib, Real-time Collab",
  "engines": { "node": "24.x" },
  "scripts": {
    "assets": "node scripts/download-asset-packs.mjs && node scripts/rebuild-manifest.mjs",
    "assets:abrams": "node scripts/download-abrams.mjs",
    "assets:sketchfab": "node scripts/download-sketchfab-pack.mjs"
  },
  "bgsEngine": {
    "version": "1.0.0",
    "models": ["bgs-spatial-01", "bgs-spatial-01-flash", "bgs-eva-01", "bgs-world-4d"],
    "animationPresets": 5243891,
    "features": [
      "spatial-reasoning-foundation-model",
      "3d-model-generation-auto-rigging-pbr",
      "realtime-collaboration-sandbox",
      "5m-animation-library",
      "4d-world-model-temporal-consistency"
    ]
  }
}
